{{ 'campaign-page.css' | asset_url | stylesheet_tag }}
{{ 'campaign-page.js' | asset_url | script_tag }}

<style>
  #shopify-section-{{ section.id }}{
    --cp-ink: {{ section.settings.ink_color }};
    --cp-paper: {{ section.settings.paper_color }};
    --cp-muted: {{ section.settings.muted_color }};
    --cp-accent: {{ section.settings.accent_color }};
    --cp-soft-bg: {{ section.settings.soft_bg_color }};
  }
  /* Publish the same custom properties on :root too, so the
     campaign-gallery section (which may render lower on the
     same template) picks up the identical color scheme. */
  :root{
    --cp-ink: {{ section.settings.ink_color }};
    --cp-paper: {{ section.settings.paper_color }};
    --cp-muted: {{ section.settings.muted_color }};
    --cp-accent: {{ section.settings.accent_color }};
    --cp-soft-bg: {{ section.settings.soft_bg_color }};
  }
</style>

<div class="cp">

  {% comment %} ===================== TOP BAR ===================== {% endcomment %}
  <div class="cp-topbar">
    <div class="container d-flex align-items-center justify-content-between py-3 flex-wrap gap-2">
      <button type="button" class="cp-hamburger d-md-none" id="cpHamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
      <div class="cp-logo">{{ section.settings.logo_text | escape }}</div>
      <div class="cp-announce d-none d-md-block">{{ section.settings.announcement_text | escape }}</div>
      {% if section.settings.choose_button_label != blank %}
        <a href="{{ section.settings.choose_button_link | default: '#' }}"
           class="btn cp-btn-shutter cp-btn-choose text-uppercase d-none d-md-inline-flex">
          {{ section.settings.choose_button_label | escape }} &nbsp;→
        </a>
      {% endif %}
      <span class="cp-hamburger-spacer d-md-none" aria-hidden="true"></span>
    </div>
  </div>

  {% comment %} ===================== HERO ===================== {% endcomment %}
  <section class="cp-hero">
    <div class="cp-hero-visual">
      {% if section.settings.banner_image %}
        <img
          class="cp-hero-img"
          src="{{ section.settings.banner_image | image_url: width: 1600 }}"
          srcset="{{ section.settings.banner_image | image_url: width: 800 }} 800w,
                  {{ section.settings.banner_image | image_url: width: 1200 }} 1200w,
                  {{ section.settings.banner_image | image_url: width: 1600 }} 1600w"
          sizes="100vw"
          alt="{{ section.settings.banner_image.alt | default: section.settings.heading | escape }}"
          width="{{ section.settings.banner_image.width }}"
          height="{{ section.settings.banner_image.height }}"
          loading="eager"
        >
      {% else %}
        <div class="cp-hero-img cp-hero-img--placeholder">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {% endif %}

      <div class="cp-hero-copy">
        {% if section.settings.heading != blank %}
          <h1 class="cp-hero-title">{{ section.settings.heading | escape }}</h1>
        {% endif %}
        {% if section.settings.subtext != blank %}
          <div class="cp-hero-sub desktop_view_text">{{ section.settings.subtext }}</div>
        {% endif %}
        {% if section.settings.subtext_small != blank %}
          <div class="cp-hero-sub mobile_view_text">{{ section.settings.subtext_small }}</div>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link | default: '#' }}"
             class="btn cp-btn-shutter cp-btn-shop d-none d-md-inline-flex desktop_view_btn">
            <span>{{ section.settings.button_label | escape }}</span> <span>→</span>
          </a>
        {% endif %}
      </div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}"
           class="btn cp-btn-shutter cp-btn-shop cp-btn-shop--overlay d-md-none mobile_view_btn">
          <span>{{ section.settings.button_label | escape }}</span> <span>→</span>
        </a>
      {% endif %}
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Campaign banner",
  "settings": [
    {
      "type": "header",
      "content": "Top bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "choose_button_label",
      "label": "Top bar button label",
      "default": "Choose Gift"
    },
    {
      "type": "url",
      "id": "choose_button_link",
      "label": "Top bar button link"
    },
    {
      "type": "header",
      "content": "Banner image"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner illustration / image"
    },
    {
      "type": "header",
      "content": "Banner text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Supporting text",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "richtext",
      "id": "subtext_small",
      "label": "Mobile Supporting text",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "ink_color",
      "label": "Text / ink color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "paper_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#5c5c5c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (buttons, sweep)",
      "default": "#f6e94f"
    },
    {
      "type": "color",
      "id": "soft_bg_color",
      "label": "Soft background color (top bar, strip)",
      "default": "#f4f4f2"
    }
  ],
  "presets": [
    {
      "name": "Campaign banner"
    }
  ]
}
{% endschema %}
